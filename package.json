{
  "name": "horojob-server",
  "version": "1.0.0",
  "description": "HoroJob REST API server",
  "private": true,
  "type": "module",
  "main": "dist/apiServer.js",
  "scripts": {
    "dev": "tsx watch src/apiServer.ts",
    "dev:api": "tsx watch src/apiServer.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "dev:all": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/apiServer.js",
    "start:api": "node dist/apiServer.js",
    "start:worker": "node dist/worker.js",
    "start:all": "node dist/server.js",
    "check": "tsc --noEmit",
    "test": "node --import tsx --test src/services/*.test.ts src/routes/*.test.ts src/runtime/*.test.ts",
    "verify": "npm run check && npm test && npm run build",
    "smoke:routes": "node --import tsx scripts/ci-route-smoke.ts",
    "ci:smoke": "npm run verify && npm run smoke:routes"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22 <23"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "mongodb": "^6.20.0",
    "playwright": "^1.58.2",
    "redis": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
